# Portfolio Rafael Chuco - Variables de entorno
# Copia este archivo como .env.local y rellena con tus valores reales

# ============================================
# CONFIGURACIÓN DE EMAIL (Opcional)
# ============================================

# Opción 1: EmailJS
# Regístrate en https://www.emailjs.com/
# NEXT_PUBLIC_EMAILJS_SERVICE_ID=tu_service_id
# NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=tu_template_id
# NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=tu_public_key

# Opción 2: Resend
# Regístrate en https://resend.com/
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxx

# ============================================
# ANALYTICS (Opcional)
# ============================================

# Google Analytics
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Vercel Analytics (automático si usas Vercel)
# No requiere configuración manual

# ============================================
# API KEYS (Si usas servicios externos)
# ============================================

# Ejemplo: API de GitHub para mostrar repos
# GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================
# NOTAS IMPORTANTES
# ============================================
# 1. NUNCA subas este archivo con valores reales a GitHub
# 2. Variables con NEXT_PUBLIC_ son accesibles en el cliente
# 3. Variables sin NEXT_PUBLIC_ solo en servidor (API routes)
# 4. Reinicia npm run dev después de cambiar variables
